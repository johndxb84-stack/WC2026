DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wc2026"
FOOTBALL_PROVIDER="mock"
FOOTBALL_API_KEY=""
COMPETITION_TIMEZONE="Asia/Dubai"
# Optional but required for durable worldwide prediction sync. Configure one option.
# Option 1: Vercel KV / Upstash REST credentials
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
# Some Vercel Redis integrations create these names instead
KV_REST_API_REDIS_URL=""
KV_REST_API_REDIS_TOKEN=""
# Option 2: Alternative Upstash variable names
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Option 3: Direct Redis connection string, e.g. redis://default:password@host:port
REDIS_URL=""

# Optional real football provider integration
API_FOOTBALL_KEY=""
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
# Map app fixture ids to provider fixture ids, e.g. {"match-14":"123456"}
FOOTBALL_FIXTURE_ID_MAP="{}"
